{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "UV Studio",
  "version": "0.3.28",
  "identifier": "link.preshow.uvstudio",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "UV Studio",
        "width": 720,
        "height": 700,
        "minWidth": 560,
        "minHeight": 480,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/hayhamLT/uvstudio/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkwQ0IwM0ZGNzg0MjdCMjYKUldRbWUwSjQvd1BMa0ZVNGl3bUhVMFArU1hBcEtCWTBvL0taZjJBbnk3OFk0SUwySC95bTBGakUK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "entitlements.plist"
    },
    "resources": {
      "../c4d-plugin/UVStudioBridge.pyp": "c4d-plugin/UVStudioBridge.pyp",
      "../c4d-plugin/README.md": "c4d-plugin/README.md",
      "../blender-plugin/uvstudio_bridge.py": "blender-plugin/uvstudio_bridge.py"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
