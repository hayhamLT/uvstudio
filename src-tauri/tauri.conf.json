{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "UV Studio",
  "version": "0.2.7",
  "identifier": "link.preshow.uvstudio",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "UV Studio",
        "width": 1440,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../c4d-plugin/UVStudioBridge.pyp": "c4d-plugin/UVStudioBridge.pyp",
      "../c4d-plugin/README.md": "c4d-plugin/README.md"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
